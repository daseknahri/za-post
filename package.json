{
  "name": "za-post-restored",
  "version": "1.0.0",
  "description": "Za Post Comment Tool - Facebook Automation (restored, clean source)",
  "main": "main.js",
  "author": "Abdelilah",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "start:base": "electron . --profile=base",
    "dev": "electron . --dev",
    "migrate": "node scripts/migrate.js king",
    "migrate:base": "node scripts/migrate.js base",
    "pack": "electron-builder --win nsis",
    "compile": "node -e \"require('bytenode').compileFile('main.js','main.jsc')\""
  },
  "dependencies": {
    "axios": "^1.13.2",
    "cloudflared": "^0.7.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "node-machine-id": "^1.1.12",
    "proxy-chain": "^2.7.0",
    "puppeteer": "^24.31.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3",
    "bytenode": "^1.5.7"
  },
  "build": {
    "appId": "com.zapost.commenttool",
    "productName": "Za Post Comment Tool",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "**/*",
      "!**/*.bak-*",
      "!scripts/fb-recon/**",
      "!**/.cache/**"
    ],
    "asarUnpack": [
      "node_modules/bytenode/**",
      "node_modules/node-machine-id/**",
      "node_modules/puppeteer/**",
      "node_modules/puppeteer-core/**"
    ]
  }
}
